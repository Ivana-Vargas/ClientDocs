DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/clientdocs?schema=public"

ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="replace-with-strong-password"
MANAGER_EMAIL="manager@example.com"
MANAGER_PASSWORD="replace-with-strong-password"

JWT_SECRET="replace-with-min-32-char-secret"
JWT_ISSUER="clientdocs"
JWT_AUDIENCE="clientdocs-web"
JWT_ACCESS_TOKEN_TTL="8h"
JWT_REFRESH_TOKEN_TTL="14d"

MAX_UPLOAD_FILE_SIZE_MB="20"
AUTH_SESSION_RETENTION_DAYS="30"
DOCUMENT_STORAGE_PROVIDER="LOCAL"

# Cloudflare R2 / S3-compatible storage (required when DOCUMENT_STORAGE_PROVIDER="S3")
R2_ENDPOINT="https://<accountid>.r2.cloudflarestorage.com"
R2_REGION="auto"
R2_BUCKET="clientdocs-documents"
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""

# Optional runtime flags
# CLEAR_AUTH_SESSIONS="true"
# FULL_DB_CLEAN="false"
# ALLOW_PRODUCTION_DB_CLEANUP="false"
